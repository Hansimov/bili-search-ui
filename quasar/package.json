{
  "name": "bili-search-ui",
  "version": "0.0.1",
  "description": "下一代B站搜索引擎",
  "productName": "blbl.top",
  "author": "Hansimov",
  "private": true,
  "scripts": {
    "bxsv": "node ../run/bxsv.js",
    "bxsv:install": "node ../run/bxsv.js install",
    "lint": "eslint --ext .js,.ts,.vue ./ ../run",
    "format": "prettier --write \"**/*.{js,ts,vue,css,html,md,json}\" --ignore-path .gitignore",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.vue-tsc.json",
    "build": "quasar build",
    "dev": "node ../run/bxsv.js start --runtime local --mode dev --foreground",
    "serve": "node ../run/bxsv.js start --runtime local --mode pro --foreground"
  },
  "dependencies": {
    "@chenfengyuan/vue-qrcode": "^2.0.0",
    "@dagrejs/dagre": "^1.1.4",
    "@quasar/extras": "^1.16.4",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.42.5",
    "@vue-flow/minimap": "^1.5.3",
    "axios": "^1.2.1",
    "http-proxy": "^1.18.1",
    "pinia": "^2.0.11",
    "qrcode": "^1.5.4",
    "quasar": "^2.16.0",
    "tiny-pinyin": "^1.3.2",
    "vue": "^3.5.16",
    "vue-router": "^4.0.12",
    "vue-showdown": "^4.2.0"
  },
  "devDependencies": {
    "@quasar/app-vite": "^1.9.0",
    "@types/node": "^20.17.23",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.1.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^22.1.0",
    "prettier": "^2.5.1",
    "typescript": "^5.6.3",
    "vite-plugin-checker": "^0.7.2",
    "vitest": "^1.6.1",
    "vue-tsc": "^2.2.8"
  },
  "engines": {
    "node": "^24 || ^22 || ^20 || ^18 || ^16",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}